  "scripts": {
    "dev": "vp pack --watch",
    "test": "vp test",
    "typecheck": "tsgo --noEmit",
    "prepublishOnly": "pnpm run build",
    "prepare": "vp config"
  },
  "devDependencies": {
    "@types/node": "latest",
    "@typescript/native-preview": "latest",
    "type-fest": "^5.4.4",
    "vite-plus": "latest"
  },
  "overrides": {
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
